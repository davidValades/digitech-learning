<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_background">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_header_curved"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginRight="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entrada Manual"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Introduce el ID del local"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:alpha="0.8" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No funciona la cámara?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Introduce el código corto de 6 dígitos del restaurante y selecciona tu mesa."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="32dp"
                android:textAlignment="center"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. Código del Local"
                        android:textColor="@color/brand_purple"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etCodigoLocal"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_card"
                        android:hint="Ej: A4X9Q2"
                        android:textColorHint="@color/text_secondary"
                        android:textColor="@color/text_primary"
                        android:inputType="textCapCharacters"
                        android:textAllCaps="true"
                        android:maxLength="6"
                        android:paddingHorizontal="16dp"
                        android:elevation="2dp"
                        android:textSize="16sp"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="24dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2. Tu Mesa"
                        android:textColor="@color/brand_purple"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_card"
                        android:elevation="2dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp">

                        <Spinner
                            android:id="@+id/spinnerMesas"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:spinnerMode="dropdown"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnConfirmarMesa"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Acceder a la Carta"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/brand_orange"
                app:cornerRadius="16dp"
                android:elevation="4dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>