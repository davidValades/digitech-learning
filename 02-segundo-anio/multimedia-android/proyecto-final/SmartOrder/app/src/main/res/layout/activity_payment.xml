<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_light">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Método de Pago"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:layout_marginBottom="32dp"/>

    <!-- Uso de 1 grupo RadioButton obligatorio -->
    <RadioGroup
        android:id="@+id/rgPaymentMethods"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">

        <RadioButton
            android:id="@+id/rbCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tarjeta de Crédito / Débito"
            android:textSize="18sp"
            android:padding="12dp"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/rbCash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Efectivo (Pagar al camarero)"
            android:textSize="18sp"
            android:padding="12dp"/>

        <RadioButton
            android:id="@+id/rbBizum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bizum"
            android:textSize="18sp"
            android:padding="12dp"/>
    </RadioGroup>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnConfirmPayment"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Confirmar y Pagar"
        android:textColor="@color/white"
        android:backgroundTint="@color/brand_orange" />

</LinearLayout>