<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_background"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_header_curved"
        android:gravity="top"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_arrow_left"
                app:tint="@color/white"
                android:layout_marginRight="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Finalizar Pago"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecciona un método"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp"/>

            <RadioGroup
                android:id="@+id/rgPaymentMethods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="32dp">

                <RadioButton
                    android:id="@+id/rbCard"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Tarjeta de Crédito / Débito"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/brand_purple"
                    android:checked="true"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"
                    android:layout_marginVertical="8dp"/>

                <RadioButton
                    android:id="@+id/rbCash"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Efectivo (Pagar al camarero)"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/brand_purple"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"
                    android:layout_marginVertical="8dp"/>

                <RadioButton
                    android:id="@+id/rbBizum"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Bizum"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/brand_purple"/>
            </RadioGroup>

            <Button
                android:id="@+id/btnConfirmPayment"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Confirmar Pedido"
                android:textColor="@color/white"
                android:backgroundTint="@color/brand_orange"
                android:textStyle="bold"
                android:elevation="4dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>